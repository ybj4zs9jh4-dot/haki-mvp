# ─── Base de données (Supabase PostgreSQL) ───────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET="[générer avec: openssl rand -base64 32]"
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase Storage (PDF rapports) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
SUPABASE_SERVICE_KEY="[service_role key depuis Supabase dashboard]"
SUPABASE_BUCKET_RAPPORTS="haki-rapports"

# ─── Resend (emails transactionnels) ──────────────────────────
RESEND_API_KEY="re_[votre clé Resend]"
EMAIL_FROM="noreply@haki.ci"

# ─── Upstash Redis (cache) ────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://[project].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[token]"

# ─── Application ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"

# ─── Seuils métier MMI-CI ────────────────────────────────────
SEUIL_COLLABORATEURS_MIN=5
SEUIL_BENCHMARK_MIN=10
TOKEN_EXPIRY_DAYS=30
RAPPORT_URL_TTL_HOURS=24
